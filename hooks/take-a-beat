#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/lib/playbook-common.sh"

stdin="$(cat 2>/dev/null || true)"
event="$(jq -r '.hook_event_name // empty' 2>/dev/null <<<"$stdin" || true)"
aid="$(playbook_agent_id "$stdin")"

# The point near which Playbook reassures, just below the native auto-compact
# threshold (~77-80%). Overridable for users who move the auto-compact point.
CALM_PCT="${PLAYBOOK_CALM_PCT:-80}"
case "$CALM_PCT" in ''|*[!0-9]*) CALM_PCT=80 ;; esac

# The anchor block costs a transcript parse, so it is computed lazily and
# memoised: the common sub-threshold PostToolUse and the offer never need it,
# only the compaction events and the beat over threshold do.
_anchor=""; _anchor_ready=""
anchor() {
  [ -n "$_anchor_ready" ] || { _anchor="$(playbook_anchor_block "$stdin")"; _anchor_ready=1; }
  printf '%s' "$_anchor"
}

reanchor_resume() {
  local a; a="$(anchor)"
  [ -n "$a" ] || return 0
  playbook_emit_context "$1" "Playbook anchor, restored first, before any orchestration scaffolding. Compaction kept what matters; nothing you need was lost.

${a}

Re-establish the one-line North Star and your current unease from the anchor above and the live work, then resume the in-flight work where you left off. Do not stop to ask whether to continue, and do not treat the compaction as a reason to wrap up. Re-state your context window as a single line of the form playbook-window: <integer> if it is not already visible."
}

case "$event" in
  PreCompact)
    playbook_emit_context "PreCompact" "## Compact Instructions
When summarising, preserve verbatim and ahead of orchestration scaffolding: the original request, the current one-line North Star, the Lessons and wrong turns (including silent wrong turns, not only errors with a stack trace), the current unease level and last movement, and the most recent playbook-window line. Re-anchor the summary on the original request and the next work.

$(anchor)"
    ;;
  PostCompact)            reanchor_resume "PostCompact" ;;
  SessionStart)
    src="$(jq -r '.source // empty' 2>/dev/null <<<"$stdin" || true)"
    if [ "$src" = "compact" ]; then
      reanchor_resume "SessionStart"
    else
      # Fresh start: if a competing context-warning hook is registered and the
      # context-calm channel has not been resolved, offer once to let Playbook
      # own it, so agents are not scared into stopping near the context limit.
      proj="$(playbook_project_dir "$stdin")"
      comp="$(playbook_competing_context_hook "$proj")"
      resolved="$(playbook_context_calm_resolved "$proj")"
      if [ -n "$comp" ] && [ -z "$resolved" ]; then
        playbook_emit_context "SessionStart" "Playbook context-calm offer: a competing context-warning hook (${comp}) is registered on this machine. Near the context limit it injects wrap-up-and-stop messages into the agent, which makes work halt early and breaks offline runs. Offer the user, once, to let Playbook own the context channel instead and keep working calmly through auto-compact. If they accept: in a GSD project set hooks.context_warnings to false in .planning/config.json; otherwise back up the settings file and remove the ${comp} PostToolUse registration from it. Then write the word owned to .claude/playbook/context-calm. If they decline, write the word declined to .claude/playbook/context-calm. Either marker stops this offer repeating. Never edit settings without the user's explicit consent, and always back up first."
      fi
    fi
    ;;
  PostToolUse)
    used="$(playbook_context_used "$stdin" || true)"
    win="$(playbook_declared_window "$stdin" || true)"
    pct="$(playbook_percent "$used" "$win" || true)"
    if [ -n "$pct" ] && [ "$pct" -ge "$CALM_PCT" ] 2>/dev/null; then
      # Fire the calm beat once per high-context window, gated on a transcript
      # sentinel so it reassures without nagging every tool call. After a
      # compaction the sentinel is dropped from the summary, so a fresh
      # reassurance can fire again in the next high-context window.
      tp="$(playbook_transcript_path "$stdin")"
      if [ -z "$tp" ] || [ ! -f "$tp" ] \
         || ! grep -qF 'Playbook context calm' "$tp" 2>/dev/null; then
        playbook_emit_context "PostToolUse" "Playbook context calm: context is at ${pct} percent used. Auto-compact is seamless and the session keeps going; the platform will not stop you. Do not wrap up early, do less, halt, or break an offline run because context is tight. You keep what matters: the original request and the North Star are re-anchored for you after compaction. Keep working at the same completeness bar.

$(anchor)"
      fi
    elif [ -z "$win" ] && [ -n "$used" ]; then
      # Work is under way but no window is declared, so the calm check cannot
      # compute a percentage. Emit one calm self-healing notice per session.
      tp="$(playbook_transcript_path "$stdin")"
      if [ -z "$tp" ] || [ ! -f "$tp" ] \
         || ! grep -qF 'Playbook context meter is off' "$tp" 2>/dev/null; then
        playbook_emit_context "PostToolUse" "Playbook context meter is off: no context window has been declared this session, so the calm context check cannot compute a percentage. Nothing is wrong and this is not urgent; state your window once as a single line of the form playbook-window: <integer> (for the one-million window state playbook-window: 1000000; for the standard window state playbook-window: 200000) so Playbook can reassure you accurately near the limit."
      fi
    fi
    ;;
  *) : ;;
esac
exit 0
